{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/types/layout,_N_T_/types/[slug]/layout,_N_T_/types/[slug]/page,_N_T_/types/high-rpm"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/types/$d$slug/__PAGE__",
    "/types/$d$slug",
    "/types",
    "/_index",
    "/_head"
  ]
}